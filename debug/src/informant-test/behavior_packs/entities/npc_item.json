{
    "format_version": "1.19.30",
    "minecraft:entity": {
        "description": {
            "identifier": "informant:npc_item",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false
        },
        "component_groups": {
            "aki_drop":{
                "minecraft:variant":{
                    "value": 0
                },
                "minecraft:loot": {
                    "table": "loot_tables/aki_drop.json"
                }
            },
            "tako_drop":{
                "minecraft:variant":{
                    "value": 1
                },
                "minecraft:loot": {
                    "table": "loot_tables/tako_drop.json"
                }
            },
            "harupon_drop":{
                "minecraft:variant":{
                    "value": 2
                },
                "minecraft:loot": {
                    "table": "loot_tables/harupon_drop.json"
                }
            }
        },
        "components": {
            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "on_damage": {
                            "filters": {
                                "any_of": [
                                    {
                                        "test": "has_tag",
                                        "subject": "other",
                                        "operator": "!=",
                                        "value": "OnAKIRequest"
                                    }
                                ],
                                "all_of": [
                                    {
                                        "test": "is_variant",
                                        "value": 0
                                    }
                                ]
                            }
                        },
                        "deals_damage": false
                    },
                    {
                        "on_damage": {
                            "filters": {
                                "any_of": [
                                    {
                                        "test": "has_tag",
                                        "subject": "other",
                                        "operator": "!=",
                                        "value": "OnTakoRequest"
                                    }
                                ],
                                "all_of": [
                                    {
                                        "test": "is_variant",
                                        "value": 1
                                    }
                                ]
                            }
                        },
                        "deals_damage": false
                    },
                    {
                        "on_damage": {
                            "filters": {
                                "any_of": [
                                    {
                                        "test": "has_tag",
                                        "subject": "other",
                                        "operator": "!=",
                                        "value": "OnHaruponRequest"
                                    }
                                ],
                                "all_of": [
                                    {
                                        "test": "is_variant",
                                        "value": 2
                                    }
                                ]
                            }
                        },
                        "deals_damage": false
                    }
                ]
            },
            "minecraft:health": {
                "value": 1,
                "max": 1
            },
            "minecraft:collision_box": {
                "height": 1,
                "width": 1
            },
            "minecraft:knockback_resistance": {
                "value": 100,
                "maximum": 100
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            "minecraft:nameable": {
                "always_show": false,
                "allow_name_tag_renaming": true
            },
            "minecraft:physics": {
                "has_gravity": true,
                "has_collision": true
            }
        },
        "events": {
            "aki_drop": {
                "add": {
                    "component_groups": [
                        "aki_drop"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "tako_drop",
                        "harupon_drop"
                    ]
                }
            },
            "tako_drop": {
                "add": {
                    "component_groups": [
                        "tako_drop"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "aki_drop",
                        "harupon_drop"
                    ]
                }
            },
            "harupon_drop": {
                "add": {
                    "component_groups": [
                        "harupon_drop"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "tako_drop",
                        "aki_drop"
                    ]
                }
            }
       }
    }
}