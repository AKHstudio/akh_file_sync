{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.snail": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "walk": "(query.is_moving) && (!query.has_target)"
            },
            {
              "angry": "query.has_target"
            }
          ]
        },
        "walk": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "default": "(!query.is_moving) && (!query.has_target)"
            },
            {
              "angry": "query.has_target"
            }
          ]
        },
        "angry": {
          "animations": [
            "angry"
          ],
          "transitions": [
            {
              "default": "!query.has_target"
            }
          ]
        }
      }
    }
  }
}
