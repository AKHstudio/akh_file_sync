{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "informant:blue_purple_helmet.player",
      "item": {
        "informant:blue_purple_hemlet": "query.owner_identifier == 'minecraft:player'"
      },
      "materials": {
        "default": "armor",
        "enchanted": "armor_enchanted"
      },
      "textures": {
        "default": "textures/color_armor/blue_purple_armor",
        "enchanted": "textures/misc/enchanted_item_glint"
      },
      "geometry": {
        "default": "geometry.colorarmorplayerhelmet"
      },
      "scripts": {
        "parent_setup": "variable.helmet_layer_visible = 0.0;",
        "animate": [
          "offset"
        ]
      },
      "animations": {
        "offset": "animation.armor.helmet.offset"
      },
      "render_controllers": ["controller.render.armor"]
    }
  }
}