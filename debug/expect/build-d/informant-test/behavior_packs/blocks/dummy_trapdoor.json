{
    "format_version": "1.21.20",
    "minecraft:block": {
        "description": {
            "identifier": "informant:dummy_trapdoor",
            "states": {
                "informant:block_facing": [0, 1, 2, 3]
            }
        },
        "components": {
            "minecraft:friction": 0.6,
            "minecraft:map_color": "#665500",
            "minecraft:light_dampening": 0,
            "minecraft:collision_box": {
                "origin": [-8, 0, -8],
                "size": [16, 16, 16]
            },
            "minecraft:selection_box": {
                "origin": [-8, 13, -8],
                "size": [16, 3, 16]
            },
            "minecraft:geometry": "geometry.dummy_trapdoor",
            "minecraft:light_emission": 0,
            "minecraft:material_instances": {
                "*": {
                    "texture": "dummy_trapdoor",
                    "render_method": "blend"
                }
            }
        },
        "permutations": [
            {
                "condition": "query.block_state('informant:block_facing') == 0",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [0, 180, 0]
                    }
                }
            },
            {
                "condition": "query.block_state('informant:block_facing') == 1",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [0, 0, 0]
                    }
                }
            },
            {
                "condition": "query.block_state('informant:block_facing') == 2",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [0, 270, 0]
                    }
                }
            },
            {
                "condition": "query.block_state('informant:block_facing') == 3",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [0, 90, 0]
                    }
                }
            }
        ]
    }
}
